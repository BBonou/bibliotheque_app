<?xml version="1.0" encoding="utf-8"?>
<!--
    Add/Edit form layout.
    Added: anneePublication field, improved margins, rounded save button.
    Switch replaced with SwitchMaterial.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Form title -->
        <TextView
            android:id="@+id/tvTitreFormulaire"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/form_title_add"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp" />

        <!-- Form card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Title field -->
                <EditText
                    android:id="@+id/etTitre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_title"
                    android:inputType="text"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <!-- Author field -->
                <EditText
                    android:id="@+id/etAuteur"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_author"
                    android:inputType="textPersonName"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <!-- ISBN field -->
                <EditText
                    android:id="@+id/etIsbn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_isbn"
                    android:inputType="text"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <!-- Publication year field -->
                <EditText
                    android:id="@+id/etAnneePublication"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_year"
                    android:inputType="number"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <!-- Availability switch -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchDisponible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_available"
                    android:textSize="15sp"
                    android:checked="true"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Save button -->
        <Button
            android:id="@+id/btnEnregistrer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_save"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:background="@drawable/btn_rounded_primary" />

    </LinearLayout>
</ScrollView>
